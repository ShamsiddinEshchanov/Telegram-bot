# 🗡️ HUNTER SYSTEM BOT - ENVIRONMENT VARIABLES
# Bu fayl'ni .env deb o'zgartirib oling va TOKEN'ni qo'shing

# ============================================================================
# TELEGRAM BOT TOKEN (MOHIM! @BotFather'dan oling)
# ============================================================================
# @BotFather'ga yozing -> /newbot -> bot nomini yozing
# Oladigon token'ni qo'ying (xotiraga bering, sirli!)
BOT_TOKEN=123456:ABC-DEF1234567890abcdef1234567890abcdef

# ============================================================================
# WEB APP URL
# ============================================================================
# Qayerda hosting qilayotganingizga qarab tanlang:

# OPTION 1: Local Testing (kompyuteringizda)
# Ishga tushirish: cd folder && python -m http.server 8000
# WEB_APP_URL=http://localhost:8000/index.html

# OPTION 2: Vercel'da (TAVSIYA)
# Signup: https://vercel.com (GitHub bilan)
# Deploy: index.html'ni drag-drop
WEB_APP_URL=https://your-app.vercel.app

# OPTION 3: Netlify'da
# Signup: https://netlify.com
# Deploy: index.html'ni drag-drop
# WEB_APP_URL=https://your-app.netlify.app

# ============================================================================
# OPTIONAL: SERVER SETTINGS
# ============================================================================
# Port (agar custom server'da joylansa)
# PORT=5000

# Host
# HOST=0.0.0.0

# ============================================================================
# QANDAY ISHLATISH:
# ============================================================================
# 1. Bu fayl'ni .env deb saqlang (asosiy folder'da)
# 2. Bot'ni chalan qilish uchun:
#    pip install python-dotenv
# 3. bot.py'da qo'shing:
#    from dotenv import load_dotenv
#    load_dotenv()
#    BOT_TOKEN = os.getenv("BOT_TOKEN")
#    WEB_APP_URL = os.getenv("WEB_APP_URL")

